# Copy to .env and fill in real values. .env is gitignored.

# Reamaze API
REAMAZE_BRAND=hairbiolabs
REAMAZE_LOGIN_EMAIL=
REAMAZE_API_TOKEN=

# Shopify (client credentials grant)
SHOPIFY_STORE_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Anthropic API
ANTHROPIC_API_KEY=

# Slack Incoming Webhook
SLACK_WEBHOOK_URL=

# Optional: comma-separated staff emails (fallback if /staff API is unavailable)
STAFF_EMAILS=

# Operational
TIMEZONE=America/Mexico_City
DRY_RUN=false
